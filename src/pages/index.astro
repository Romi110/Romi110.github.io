---
import Base from '../layouts/Base.astro';
---
<Base title="hi :3" theme="home">
  <style is:global>
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 48px;
      padding: 40px 20px;
    }

    /* ── Header ── */
    .site-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 8vw, 5rem);
      letter-spacing: 0.04em;
      color: var(--ink);
      text-align: center;
    }

    /* ── Social icons ── */
    .socials {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      color: var(--muted);
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
    }

    .social-link:hover {
      border-color: var(--muted);
      color: var(--ink);
    }

    .social-link svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }

    /* ── Project buttons ── */
    .projects {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }

    .project-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 140px;
      height: 140px;
      border-radius: var(--radius);
      background: var(--bg3);
      border: 1.5px solid var(--border);
      color: var(--ink);
      text-decoration: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: background 0.2s, border-color 0.2s, transform 0.15s;
      cursor: pointer;
    }

    .project-btn:hover {
      background: var(--bg2);
      border-color: var(--border);
      transform: translateY(-2px);
    }

    .project-btn .btn-icon {
      font-size: 2.4rem;
      line-height: 1;
    }

    .project-btn .btn-label {
      text-align: center;
      line-height: 1.3;
      color: var(--muted);
    }
  </style>

  <h1 class="site-name">hi :3</h1>

  <!-- Social media links (empty for now) -->
  <div class="socials">
    <!-- GitHub -->
    <a class="social-link" href="#" title="GitHub">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.467-1.332-5.467-5.93 0-1.31.468-2.382 1.236-3.22-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.838 1.235 1.91 1.235 3.22 0 4.61-2.807 5.625-5.48 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .322.216.694.825.576C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>
    <!-- LinkedIn -->
    <a class="social-link" href="#" title="LinkedIn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <!-- Twitter / X -->
    <a class="social-link" href="#" title="Twitter / X">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.905-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
  </div>

  <!-- Project buttons -->
  <div class="projects">
    <a class="project-btn" href="/kettlebell" title="Kettlebell Guide">
      <span class="btn-icon">🏋️</span>
      <span class="btn-label">Kettlebell how to</span>
    </a>
    <a class="project-btn" href="/reading" title="Reading List">
      <span class="btn-icon">📚</span>
      <span class="btn-label">Romesh's Reads</span>
    </a>
    <a class="project-btn" href="/roma" title="Book of Roma">
      <span class="btn-icon">💡</span>
      <span class="btn-label">Book of Wisdom</span>
    </a>
  </div>
</Base>
