    <!-- PANEL: SOURCES -->
    <div class="roma-panel" id="panel-sources">
      <p class="sources-intro">The ideas in this book did not originate here. Below are the texts and thinkers they came from. Organized by tradition, with notes on where each one connects.</p>
      <div class="sources-accordion">

        <!-- Stoicism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('stoicism')" id="acc-btn-stoicism">
            Stoicism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-stoicism">
            <div class="source-entry">
              <div class="source-title">Meditations</div>
              <div class="source-author">Marcus Aurelius — ~170 CE</div>
              <div class="source-annotation">The private journal of a Roman emperor who practiced Stoicism daily. The most direct source for Tenets 1, 4, 5, and 7. Read the Gregory Hays translation.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 1</span>
                <span class="source-tenet-chip">Tenet 4</span>
                <span class="source-tenet-chip">Tenet 5</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Enchiridion</div>
              <div class="source-author">Epictetus — ~100 CE</div>
              <div class="source-annotation">A forty-page handbook of Stoic practice. The source of the core distinction between what is and is not in your control — the backbone of Tenet 1. Unsparing and direct.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 1</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Letters from a Stoic</div>
              <div class="source-author">Seneca — ~65 CE</div>
              <div class="source-annotation">Letters to a friend on how to live. Warmer than Epictetus, more literary than Marcus. Especially strong on time, mortality, and Tenet 4.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 4</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Buddhism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('buddhism')" id="acc-btn-buddhism">
            Buddhism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-buddhism">
            <div class="source-entry">
              <div class="source-title">Peace Is Every Step</div>
              <div class="source-author">Thich Nhat Hanh — 1991</div>
              <div class="source-annotation">Short chapters, plain language, practical. The best entry point for mindfulness as a daily practice. Directly relevant to Tenets 2, 3, and 4.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 2</span>
                <span class="source-tenet-chip">Tenet 3</span>
                <span class="source-tenet-chip">Tenet 4</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">The Dhammapada</div>
              <div class="source-author">~300 BCE</div>
              <div class="source-annotation">The oldest collection of the Buddha's teachings. Short verses. The first line — 'Mind is the forerunner of all actions' — is Tenet 1 in a sentence.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 1</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Zen Mind, Beginner's Mind</div>
              <div class="source-author">Shunryu Suzuki — 1970</div>
              <div class="source-annotation">The essential Zen text for a Western reader. Covers presence, beginner's mind, and daily practice. Relevant to Tenets 2, 4, and 7.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 2</span>
                <span class="source-tenet-chip">Tenet 4</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Taoism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('taoism')" id="acc-btn-taoism">
            Taoism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-taoism">
            <div class="source-entry">
              <div class="source-title">Tao Te Ching</div>
              <div class="source-author">Lao Tzu — ~600 BCE</div>
              <div class="source-annotation">Eighty-one short chapters. Read the Ursula K. Le Guin translation for readability. The source of the ideas behind Tenets 2, 3, and 7.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 2</span>
                <span class="source-tenet-chip">Tenet 3</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Chuang Tzu</div>
              <div class="source-author">~300 BCE</div>
              <div class="source-annotation">More playful than the Tao Te Ching. Uses stories and absurdist humor to point at the same truths. Good for Tenets 3 and 7.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 3</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Hindu Philosophy -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('hindu')" id="acc-btn-hindu">
            Hindu Philosophy
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-hindu">
            <div class="source-entry">
              <div class="source-title">The Bhagavad Gita</div>
              <div class="source-author">~200 BCE</div>
              <div class="source-annotation">A dialogue on duty, action, attachment, and the self. The source of Tenet 2's teaching on non-attachment to outcomes. Read the Barbara Stoler Miller translation.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 2</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">The Upanishads</div>
              <div class="source-author">~800–200 BCE</div>
              <div class="source-annotation">The philosophical heart of the Hindu tradition. Core to Tenet 3 — the interconnection of all selves in the deeper self. The Juan Mascaró translation is accessible.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 3</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Sufism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('sufism')" id="acc-btn-sufism">
            Sufism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-sufism">
            <div class="source-entry">
              <div class="source-title">The Essential Rumi</div>
              <div class="source-author">Rumi — translated by Coleman Barks, 1995</div>
              <div class="source-annotation">Rumi's central themes — return to presence, the pull of what you love, the ego as veil — run throughout this book.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 4</span>
                <span class="source-tenet-chip">Tenet 6</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">The Alchemy of Happiness</div>
              <div class="source-author">Al-Ghazali — ~1100 CE</div>
              <div class="source-annotation">A practical guide to self-knowledge from the greatest Islamic philosopher. Directly relevant to Tenet 7's treatment of the lower self.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Existentialism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('existentialism')" id="acc-btn-existentialism">
            Existentialism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-existentialism">
            <div class="source-entry">
              <div class="source-title">Man's Search for Meaning</div>
              <div class="source-author">Viktor Frankl — 1946</div>
              <div class="source-annotation">Frankl's account of surviving the concentration camps and the philosophy of meaning he built from it. The most powerful modern argument for Tenet 6. Short, dense, unforgettable.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 6</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">The Myth of Sisyphus</div>
              <div class="source-author">Albert Camus — 1942</div>
              <div class="source-annotation">The foundational absurdist text: life has no inherent meaning, and the honest response is full engagement anyway — not resignation. Relevant to Tenet 6.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 6</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Beyond Good and Evil</div>
              <div class="source-author">Friedrich Nietzsche — 1886</div>
              <div class="source-annotation">The will to power as self-mastery, not domination. Relevant to Tenets 5 and 7. Start here before Thus Spoke Zarathustra.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 5</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Confucianism -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('confucianism')" id="acc-btn-confucianism">
            Confucianism
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-confucianism">
            <div class="source-entry">
              <div class="source-title">The Analects</div>
              <div class="source-author">Confucius — ~500 BCE</div>
              <div class="source-annotation">Short records of teachings focused entirely on right conduct in relationships and daily life. The most practical ancient ethics text. Directly relevant to Tenets 5 and 7. Read the Edward Slingerland translation.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 5</span>
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Modern & Western -->
        <div class="sources-tradition">
          <button class="sources-tradition-btn" onclick="toggleAccordion('modern')" id="acc-btn-modern">
            Modern &amp; Western
            <span class="sources-chevron">&#9660;</span>
          </button>
          <div class="sources-tradition-body" id="acc-body-modern">
            <div class="source-entry">
              <div class="source-title">Mere Christianity</div>
              <div class="source-author">C.S. Lewis — 1952</div>
              <div class="source-annotation">The clearest modern articulation of the Christian insight on pride — the backbone of Tenet 7. Lewis writes for the unconvinced, which makes him unusually clear.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Pragmatism</div>
              <div class="source-author">William James — 1907</div>
              <div class="source-annotation">The American tradition most aligned with Tenet 5. James argued that belief is not separate from behavior — what you do shapes what you think, not just the reverse.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 5</span>
              </div>
            </div>
            <div class="source-entry">
              <div class="source-title">Ego Is the Enemy / The Obstacle Is the Way</div>
              <div class="source-author">Ryan Holiday — 2016 / 2014</div>
              <div class="source-annotation">Modern Stoic applications. Practical, short, well-sourced. Ego Is the Enemy is directly relevant to Tenet 7.</div>
              <div class="source-tenets">
                <span class="source-tenet-chip">Tenet 7</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div><!-- /.wrap -->

  <!-- Hidden data for client JS -->
  <div id="roma-data" data-json={JSON.stringify(romaData)} hidden></div>

  <script is:inline>
    // ── Global state ─────────────────────────────────────────────────
    let romaData = null;
    let currentTenetId = 'mind';

    // ── Helpers ──────────────────────────────────────────────────────
    function esc(s) {
      if (!s) return '';
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function em(s) {
      if (!s) return '';
      return esc(s).replace(/\*([^*]+)\*/g, '<em>$1</em>');
    }

    // ── Theme ────────────────────────────────────────────────────────
    function applyRomaTheme(dark) {
      document.documentElement.setAttribute('data-theme', dark ? 'roma-dark' : 'roma');
      var btn = document.getElementById('roma-theme-btn');
      if (btn) btn.textContent = dark ? '☀ Light' : '☽ Dark';
    }

    function toggleRomaTheme() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'roma-dark';
      var next = !isDark;
      localStorage.setItem('roma-theme', next ? 'dark' : 'light');
      applyRomaTheme(next);
    }

    // ── Panel switching ──────────────────────────────────────────────
    function showPanel(id) {
      document.querySelectorAll('.roma-panel').forEach(function(p) {
        p.classList.remove('active');
      });
      document.querySelectorAll('.roma-tab').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.panel === id);
      });
      var panel = document.getElementById('panel-' + id);
      if (panel) panel.classList.add('active');
    }

    // ── Tenet rendering ──────────────────────────────────────────────
    function renderTenet(tenet) {
      var quotesHtml = tenet.quotes.map(function(q) {
        return '<div class="tenet-quote-card">' +
          '<div class="tenet-quote-text">' + em(q.text) + '</div>' +
          '<div class="tenet-quote-attr"><strong>' + esc(q.attr) + '</strong> / ' + esc(q.source) + '</div>' +
          '</div>';
      }).join('');

      var meaningHtml = tenet.meaning.map(function(p) {
        return '<p>' + em(p) + '</p>';
      }).join('');

      var realLifeHtml = tenet.realLife.map(function(item) {
        return '<div class="tenet-reallife-item"><strong>' + esc(item.bold) + '</strong> ' + em(item.body) + '</div>';
      }).join('');

      var notThisHtml = tenet.notThis.map(function(p) {
        return '<p>' + em(p) + '</p>';
      }).join('');

      var rememberHtml = tenet.remember.map(function(r) {
        return '<li>' + esc(r) + '</li>';
      }).join('');

      var practiceHtml = tenet.practice
        ? '<div class="tenet-practice"><span class="tenet-practice-label">PRACTICE</span><span class="tenet-practice-text">' + esc(tenet.practice) + '</span></div>'
        : '';

      return '<div class="tenet-number">TENET ' + tenet.number + '</div>' +
        '<h2 class="tenet-title">' + esc(tenet.title) + '</h2>' +
        '<div class="tenet-statement"><div class="tenet-statement-text">' + esc(tenet.statement) + '</div></div>' +
        practiceHtml +
        '<div class="tenet-section-label">WHAT OTHERS HAVE SAID</div>' +
        '<div class="tenet-quotes">' + quotesHtml + '</div>' +
        '<div class="tenet-section-label">WHAT THIS MEANS</div>' +
        '<div class="tenet-prose">' + meaningHtml + '</div>' +
        '<div class="tenet-section-label">IN REAL LIFE</div>' +
        '<div class="tenet-reallife">' + realLifeHtml + '</div>' +
        '<div class="tenet-section-label">WHAT THIS IS NOT</div>' +
        '<div class="tenet-prose">' + notThisHtml + '</div>' +
        '<div class="tenet-remember">' +
          '<div class="tenet-remember-label">REMEMBER</div>' +
          '<ul class="tenet-remember-list">' + rememberHtml + '</ul>' +
        '</div>';
    }

    function showTenet(id) {
      currentTenetId = id;

      // Update all nav buttons (sidebar + pill)
      document.querySelectorAll('[data-tenet]').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.tenet === id);
      });

      var tenet = romaData.tenets.find(function(t) { return t.id === id; });
      if (!tenet) return;

      var content = document.getElementById('tenet-content');
      if (content) content.innerHTML = renderTenet(tenet);
    }

    function jumpToTenet(number) {
      var ids = ['mind', 'grip', 'wall', 'present', 'action', 'making', 'ego'];
      showPanel('tenets');
      showTenet(ids[number - 1]);
    }

    // ── Stories rendering ────────────────────────────────────────────
    function renderStories() {
      var grid = document.getElementById('stories-grid');
      if (!grid) return;

      var tenetNames = ['', 'Mind', 'Grip', 'Wall', 'Present', 'Action', 'Making', 'Humility'];

      var html = romaData.stories.map(function(story) {
        var chips = story.tenets.map(function(n) {
          return '<span class="story-tenet-chip">' + n + ' — ' + tenetNames[n] + '</span>';
        }).join('');

        var paragraphs = story.paragraphs.map(function(p) {
          return '<p>' + esc(p) + '</p>';
        }).join('');

        var moralHtml = story.moral
          ? '<div class="story-moral">' + esc(story.moral) + '</div>'
          : '';

        return '<div class="story-card" id="story-' + story.id + '" data-tenets="' + story.tenets.join(',') + '">' +
          '<div class="story-card-title">' + esc(story.title) + '</div>' +
          '<div class="story-card-tenets">' + chips + '</div>' +
          '<div class="story-card-excerpt">' + esc(story.excerpt) + '</div>' +
          '<div class="story-body">' + paragraphs + moralHtml + '</div>' +
          '<button class="story-card-read-btn" onclick="expandStory(\'' + story.id + '\', this)">Read</button>' +
          '</div>';
      }).join('');

      grid.innerHTML = html;
    }

    function filterStories(tenet, btn) {
      // Update filter button active state
      document.querySelectorAll('.stories-filter-btn').forEach(function(b) {
        b.classList.remove('active');
      });
      if (btn) btn.classList.add('active');

      // Show/hide cards
      document.querySelectorAll('.story-card').forEach(function(card) {
        if (tenet === 'all') {
          card.classList.remove('hidden');
        } else {
          var tenets = card.dataset.tenets.split(',').map(Number);
          card.classList.toggle('hidden', tenets.indexOf(tenet) === -1);
        }
      });
    }

    function expandStory(id, btn) {
      var card = document.getElementById('story-' + id);
      if (!card) return;

      var isExpanded = card.classList.contains('expanded');

      // Collapse all
      document.querySelectorAll('.story-card').forEach(function(c) {
        c.classList.remove('expanded');
        var readBtn = c.querySelector('.story-card-read-btn');
        if (readBtn) readBtn.textContent = 'Read';
      });

      // Expand this one if it wasn't already expanded
      if (!isExpanded) {
        card.classList.add('expanded');
        if (btn) btn.textContent = 'Close';
      }
    }

    // ── Sources accordion ────────────────────────────────────────────
    function toggleAccordion(id) {
      var body = document.getElementById('acc-body-' + id);
      var btn = document.getElementById('acc-btn-' + id);
      if (!body || !btn) return;

      var isOpen = body.classList.contains('open');
      body.classList.toggle('open', !isOpen);
      btn.classList.toggle('open', !isOpen);
    }

    // ── Password gate ────────────────────────────────────────────────
    function checkRomaPassword() {
      var input = document.getElementById('roma-gate-input');
      if (!input) return;

      if (input.value.toLowerCase() === 'roma') {
        localStorage.setItem('roma-unlocked', 'true');
        var gate = document.getElementById('roma-gate');
        if (gate) {
          gate.classList.add('hidden');
          setTimeout(function() { gate.style.display = 'none'; }, 450);
        }
      } else {
        input.classList.remove('shake');
        // Force reflow to restart animation
        void input.offsetWidth;
        input.classList.add('shake');
        input.value = '';
        setTimeout(function() { input.classList.remove('shake'); }, 400);
      }
    }

    // ── Init ─────────────────────────────────────────────────────────
    (function init() {
      // Gate check
      var gate = document.getElementById('roma-gate');
      if (localStorage.getItem('roma-unlocked') === 'true') {
        if (gate) gate.style.display = 'none';
      }

      // Theme
      var savedTheme = localStorage.getItem('roma-theme');
      applyRomaTheme(savedTheme === 'dark');

      // Parse data
      var dataEl = document.getElementById('roma-data');
      if (dataEl) {
        romaData = JSON.parse(dataEl.dataset.json);
      }

      // Render first tenet and stories
      if (romaData) {
        showTenet('mind');
        renderStories();
      }
    })();
  </script>
</Base>
